{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=workflowapp.db"
  },
  "Jwt": {
    "Issuer": "WorkflowApp.Api", // JWTの発行者
    "Audience": "WorkflowApp.Client", // JWTの受信者
    "SecretKey": "THIS_IS_DEVELOPMENT_ONLY_SECRET_KEY_12345", // JWTの署名に使用する秘密鍵（開発環境用）
    "ExpiresMinutes": "60" // JWTの有効期限（分）
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information", // デフォルトのログレベル
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*", // 許可されたホスト（すべてのホストを許可）
  "SeedData": {
    "Enabled": true
  },
  "SeedUsers": [
    {
      "LoginId": "applicant01",
      "Password": "ChangeMe_Applicant_123!",
      "Role": "Applicant"
    },
    {
      "LoginId": "approver01",
      "Password": "ChangeMe_Approver_123!",
      "Role": "Approver"
    }
  ]
